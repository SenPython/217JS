{
  "entities": {
    "LatLng": {
      "title": "LatLng",
      "description": "Geographical coordinates and accuracy status.",
      "type": "object",
      "properties": {
        "lat": {
          "type": "number",
          "description": "Latitude position"
        },
        "lng": {
          "type": "number",
          "description": "Longitude position"
        },
        "accuracy": {
          "type": "number",
          "description": "Accuracy in meters"
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp when location updated"
        }
      },
      "required": ["lat", "lng", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "Represents an active Instagram chat participant and their streaming location.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique Google user ID or email hash tag"
        },
        "name": {
          "type": "string",
          "description": "Full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "avatar": {
          "type": "string",
          "description": "Avatar image URL"
        },
        "status": {
          "type": "string",
          "enum": ["online", "offline"],
          "description": "User online connection status"
        },
        "isSharingLocation": {
          "type": "boolean",
          "description": "Whether coordinates sharing is enabled"
        },
        "location": {
          "type": "object",
          "$ref": "#/entities/LatLng",
          "description": "Current sharing location coordinates"
        },
        "lastSeen": {
          "type": "number",
          "description": "Timestamp of the last active state"
        }
      },
      "required": ["id", "name", "email", "status", "isSharingLocation"]
    },
    "Message": {
      "title": "Message",
      "description": "Represents a physical chat bubble message with optional multimedia links.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique message identifier"
        },
        "roomId": {
          "type": "string",
          "description": "Active chat room identifier"
        },
        "senderId": {
          "type": "string",
          "description": "Sender user ID"
        },
        "senderName": {
          "type": "string",
          "description": "Display name of sender"
        },
        "senderAvatar": {
          "type": "string",
          "description": "Avatar URL of sender"
        },
        "text": {
          "type": "string",
          "description": "Message textual content"
        },
        "mediaUrl": {
          "type": "string",
          "description": "Base64 or external hyperlinked image or video"
        },
        "mediaType": {
          "type": "string",
          "enum": ["image", "video"],
          "description": "Type of attached media asset"
        },
        "timestamp": {
          "type": "number",
          "description": "Timestamp when message sent"
        }
      },
      "required": ["id", "roomId", "senderId", "senderName", "senderAvatar", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public and private user positions, status feeds, and user account metadata."
    },
    "rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Log of text-based and visual photo/video messages shared across direct rooms and public group chat channels."
    }
  }
}
